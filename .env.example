# =============================================
# BANCO DE DADOS
# =============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/leadflow"

# =============================================
# AUTENTICAÇÃO
# =============================================
JWT_SECRET="sua-chave-jwt-super-secreta-aqui"
JWT_REFRESH_SECRET="sua-chave-refresh-super-secreta-aqui"
NEXTAUTH_SECRET="sua-chave-nextauth-aqui"
NEXTAUTH_URL="http://localhost:3000"

# =============================================
# APLICAÇÃO
# =============================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# =============================================
# WHATSAPP (Evolution API)
# =============================================
EVOLUTION_API_URL="https://sua-instancia-evolution.com"
EVOLUTION_API_KEY="sua-api-key-evolution"
EVOLUTION_INSTANCE_NAME="LeadFlow"

# =============================================
# INTELIGÊNCIA ARTIFICIAL
# =============================================
OPENAI_API_KEY="sk-sua-chave-openai"
OPENAI_MODEL="gpt-4"

# =============================================
# N8N
# =============================================
N8N_URL="https://sua-instancia-n8n.com"
N8N_API_KEY="sua-api-key-n8n"

# =============================================
# EMAIL (Resend)
# =============================================
RESEND_API_KEY="sua-chave-resend"
FROM_EMAIL="noreply@seudominio.com"

# =============================================
# REDIS (Cache)
# =============================================
REDIS_URL="redis://localhost:6379"

# =============================================
# STORAGE
# =============================================
BLOB_READ_WRITE_TOKEN="sua-token-vercel-blob"
